# Copy to secrets/secrets.yml (chmod 600). That file is gitignored — never commit it.

# Tailscale OAuth client key (tskey-client-...), used only for (re)registration.
# Generate in the Tailscale admin console with tag:container.
tailscale_authkey: ""

# shadowsocks-2022 pre-shared key for sing-box. Generate: openssl rand -base64 32
# Rotating it requires updating every client.
shadowsocks_psk: ""

# Ubuntu Pro token from https://ubuntu.com/pro/dashboard (free for personal use).
# Leave empty to skip attaching.
ubuntu_pro_token: ""
