{
  "log": { "level": "warn", "timestamp": true },
  "dns": {
    "servers": [
      { "tag": "doh", "type": "https", "server": "1.1.1.1" }
    ]
  },
  "inbounds": [
    {
      "type": "shadowsocks",
      "tag": "ss-in",
      "listen": "0.0.0.0",
      "listen_port": {{ singbox_port }},
      "method": "2022-blake3-aes-256-gcm",
      "password": {{ shadowsocks_psk | to_json }}
    }
  ],
  "outbounds": [
    { "type": "direct", "tag": "direct" }
  ],
  "route": {
    "default_domain_resolver": { "server": "doh" },
    "final": "direct"
  }
}
